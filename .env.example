# ============================================================================
# Talasin — server-side environment variables
# ----------------------------------------------------------------------------
# Copy this file to `.env.local` and fill in real values. NEVER commit
# `.env.local`. NONE of these are prefixed NEXT_PUBLIC_ — so none of them can
# leak into the client bundle (Next.js only inlines NEXT_PUBLIC_* into client
# code). The browser never holds any of these secrets.
# ============================================================================

# --- Gemini (Google AI Studio, free tier) ----------------------------------
# Get a key at https://aistudio.google.com/apikey
GEMINI_API_KEY=

# --- Supabase (server-side, service-role only) ------------------------------
# Project URL, e.g. https://xxxxxxxx.supabase.co
SUPABASE_URL=
# Service-role key (Project Settings → API → service_role). Server-only.
# This BYPASSES RLS. It must NEVER appear in client code or NEXT_PUBLIC_*.
SUPABASE_SERVICE_ROLE_KEY=

# --- Passphrase gate --------------------------------------------------------
# scrypt (memory-hard KDF) hash of (passphrase + TALASIN_PASSPHRASE_PEPPER),
# self-describing format: scrypt:N:r:p:saltB64url:hashB64url. Never store the
# plaintext passphrase. Generate with (prints ready-to-paste env lines):
#   node scripts/hash-passphrase.mjs "your-passphrase" "your-pepper"
# GOTCHA: the older $-delimited variant of this format is also accepted, but
# `$` in .env files is treated as VARIABLE EXPANSION by Next and silently
# mangles the value unless every `$` is escaped as `\$`. The colon format
# avoids this entirely.
TALASIN_PASSPHRASE_HASH=
# Pepper mixed into the passphrase before the KDF runs (extra secret, server-only).
TALASIN_PASSPHRASE_PEPPER=
# HMAC key used to sign/verify the session cookie. Use a long random string:
#   node -e "console.log(require('crypto').randomBytes(48).toString('base64url'))"
TALASIN_SESSION_SECRET=

# --- Admin / top-up ---------------------------------------------------------
# Shared token required (via `x-talasin-admin` header) to run POST /api/game/topup
# and the seed script. Use a long random string.
TALASIN_ADMIN_TOKEN=
# Bearer token the weekly Vercel Cron sends to GET /api/cron/topup; unset = cron fails closed.
CRON_SECRET=

# --- App config -------------------------------------------------------------
# Fixed timezone used to compute the local calendar day for streaks.
# Single-user app; defaults to Asia/Manila if unset.
TALASIN_TZ=Asia/Manila
